{
  "name": "retrotrack.rommanager",
  "description": "A ROM manager for RetroAchievements and RetroTrack",
  "keywords": [
    "electron",
    "react",
    "retroachievements",
    "retrotrack",
    "rom-manager"
  ],
  "license": "MIT",
  "author": "RetroTrack",
  "main": "./.erb/dll/main.bundle.dev.js",
  "scripts": {
    "build": "concurrently \"npm run build:main\" \"npm run build:renderer\"",
    "build:dll": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ./.erb/scripts/ts-node-register.js --no-warnings\" webpack --config ./.erb/configs/webpack.config.renderer.dev.dll.ts",
    "build:main": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ./.erb/scripts/ts-node-register.js --no-warnings\" webpack --config ./.erb/configs/webpack.config.main.prod.ts",
    "build:renderer": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ./.erb/scripts/ts-node-register.js --no-warnings\" webpack --config ./.erb/configs/webpack.config.renderer.prod.ts",
    "postinstall": "node -r ./.erb/scripts/ts-node-register.js .erb/scripts/check-native-dep.js && cd release/app && npm install && cd ../.. && npm run build:dll",
    "lint": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "package": "node -r ./.erb/scripts/ts-node-register.js ./.erb/scripts/clean.js dist && npm run build && electron-builder build --publish never && npm run build:dll",
    "publish": "node -r ./.erb/scripts/ts-node-register.js ./.erb/scripts/clean.js dist && npm run build && electron-builder build --publish always && npm run build:dll",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "prestart": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ./.erb/scripts/ts-node-register.js --no-warnings\" webpack --config ./.erb/configs/webpack.config.main.dev.ts",
    "start": "node -r ./.erb/scripts/ts-node-register.js ./.erb/scripts/check-port-in-use.js && npm run prestart && npm run start:renderer",
    "start:main": "concurrently -k -P \"cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --watch --config ./.erb/configs/webpack.config.main.dev.ts\" \"node ./.erb/scripts/launch-electronmon.js {@}\" --",
    "start:preload": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ./.erb/scripts/ts-node-register.js --no-warnings\" webpack --config ./.erb/configs/webpack.config.preload.dev.ts",
    "start:renderer": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ./.erb/scripts/ts-node-register.js --no-warnings\" webpack serve --config ./.erb/configs/webpack.config.renderer.dev.ts"
  },
  "browserslist": [
    "last 1 chrome version"
  ],
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ]
  },
  "dependencies": {
    "@electron/notarize": "^3.1.1",
    "@tanstack/react-query": "^5.101.2",
    "electron-debug": "^4.1.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@svgr/webpack": "^8.1.0",
    "@teamsupercell/typings-for-css-modules-loader": "^2.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/discord-rpc": "^4.0.11",
    "@types/node": "^25",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "chalk": "^4.1.2",
    "concurrently": "^10.0.3",
    "core-js": "^3.49.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "detect-port": "^2.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-devtools-installer": "^4.0.0",
    "electronmon": "^2.0.4",
    "eslint": "^9",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.9.5",
    "react-refresh": "^0.18.0",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^6",
    "url-loader": "^4.1.1",
    "webpack": "^5.108.4",
    "webpack-bundle-analyzer": "^5.3.1",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^5",
    "webpack-merge": "^6.0.1"
  },
  "build": {
    "productName": "RetroTrack ROM Manager",
    "appId": "com.retrotrack.rommanager",
    "asar": true,
    "npmRebuild": false,
    "afterSign": ".erb/scripts/notarize.js",
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "dist",
      "node_modules",
      "package.json"
    ],
    "mac": {
      "notarize": false,
      "target": {
        "target": "default",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Bregann",
      "repo": "RetroTrack",
      "releaseType": "release"
    },
    "generateUpdatesFilesForAllChannels": false
  },
  "overrides": {
    "node-gyp": "^12.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=14.x",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=7.x",
      "onFail": "error"
    }
  },
  "electronmon": {
    "patterns": [
      "!**/**",
      "src/main/**",
      ".erb/dll/**"
    ],
    "logLevel": "quiet"
  }
}
